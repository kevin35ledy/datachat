# ─────────────────────────────────────────────────────────────────────────────
# DataChat — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# Ne jamais committer .env dans le dépôt
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=                          # Optionnel
LITELLM_DEFAULT_MODEL=claude-sonnet-4-6
LITELLM_SUMMARY_MODEL=claude-haiku-4-5-20251001
OLLAMA_API_BASE=http://localhost:11434   # Optionnel — LLM local

# ── Vector store (Qdrant) ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                          # Seulement pour Qdrant Cloud

# ── Base de l'application ───────────────────────────────────────────────────
# Dev (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./datachat.db
# Prod (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/datachat

# ── Sécurité ─────────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRY_MINUTES=480

# ── Redis (Celery) ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Limites de sécurité ──────────────────────────────────────────────────────
MAX_QUERY_ROWS=1000
QUERY_TIMEOUT_SECONDS=30
MAX_AUDIT_TABLES=500

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60

# ── Mode debug ───────────────────────────────────────────────────────────────
DEBUG=true
SHOW_SQL_ERRORS=true
